# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

# @react-native-firebase: pull firebase-ios-sdk as static frameworks so it
# links without enabling use_frameworks! app-wide (RN 0.83 static build).
$RNFirebaseAsStaticFramework = true

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'auxi' do
  config = use_native_modules!

  # @react-native-firebase: firebase-ios-sdk 11.x links statically here (CI builds
  # WITHOUT USE_FRAMEWORKS, so use_frameworks! is off). In that static-library
  # mode FirebaseMessaging compiles `@import FirebaseCore;` (and FirebaseCore in
  # turn `@import`s FirebaseCoreInternal/GoogleUtilities/...), so every pod in the
  # Firebase `@import` chain needs a clang module map. `pod install` only flagged
  # GoogleUtilities, but the Release archive compile fails on the rest of the
  # cascade ("Module 'FirebaseCore' not found"). Opt the whole chain into modular
  # headers rather than enabling use_frameworks! app-wide, which risks
  # Hermes/RN-core/folly non-modular-header breakage on RN 0.83.
  pod 'FirebaseCore', :modular_headers => true
  pod 'FirebaseCoreInternal', :modular_headers => true
  pod 'FirebaseCoreExtension', :modular_headers => true
  pod 'FirebaseInstallations', :modular_headers => true
  pod 'FirebaseMessaging', :modular_headers => true
  pod 'GoogleDataTransport', :modular_headers => true
  pod 'GoogleUtilities', :modular_headers => true
  pod 'PromisesObjC', :modular_headers => true
  pod 'nanopb', :modular_headers => true

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # Xcode 26 / Apple clang has stricter consteval enforcement that breaks
    # fmt 11.0.x's FMT_STRING macros. Force fmt to skip consteval paths.
    installer.pods_project.targets.each do |target|
      if target.name == 'fmt'
        target.build_configurations.each do |config|
          existing = config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] || ['$(inherited)']
          existing = [existing] unless existing.is_a?(Array)
          existing << 'FMT_USE_CONSTEVAL=0' unless existing.include?('FMT_USE_CONSTEVAL=0')
          config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] = existing
        end
      end
    end

    # fmt's base.h hardcodes #define FMT_USE_CONSTEVAL — patch in an #ifndef
    # guard so the GCC_PREPROCESSOR_DEFINITIONS=FMT_USE_CONSTEVAL=0 wins.
    base_h = File.join(installer.sandbox.root, 'fmt/include/fmt/base.h')
    if File.exist?(base_h) && File.read(base_h) !~ /^#ifndef FMT_USE_CONSTEVAL$/
      content = File.read(base_h)
      patched = content.sub(
        /(\/\/ Detect consteval, C\+\+20 constexpr extensions and std::is_constant_evaluated\.\n)(#if !defined\(__cpp_lib_is_constant_evaluated\))/,
        "\\1#ifndef FMT_USE_CONSTEVAL\n\\2"
      ).sub(
        /(#  define FMT_USE_CONSTEVAL 0\n#endif\n)(#if FMT_USE_CONSTEVAL\n)/,
        "\\1#endif  // FMT_USE_CONSTEVAL\n\\2"
      )
      File.write(base_h, patched)
      Pod::UI.puts 'Patched fmt/base.h to honor FMT_USE_CONSTEVAL override'.yellow
    end
  end
end
