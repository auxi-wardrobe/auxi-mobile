# fastlane
#
# It is recommended to not store the screenshots in the git repo. Instead, use fastlane to re-generate the
# screenshots whenever they are needed.
# For more information about the recommended setup visit:
# https://docs.fastlane.tools/best-practices/source-control/

**/fastlane/report.xml
**/fastlane/Preview.html
**/fastlane/screenshots
**/fastlane/test_output
**/fastlane/.env
**/fastlane/.env.*

# QA findings screenshots — ephemeral sim/Figma captures, regenerate on demand; do not commit
docs/qa-findings/screenshots/

# Design-review screenshots — ephemeral sim/Figma captures (review evidence), not source; do not commit
docs/design-reviews/screenshots/
!**/fastlane/.env.default
**/fastlane/*.p8
**/fastlane/AuthKey_*.p8

# Bundle artifact
*.jsbundle

# Ruby / CocoaPods
**/Pods/
/vendor/bundle/
ios/vendor/bundle/

# Temporary files created by Metro to check the health of the file watcher
.metro-health-check*

# testing
/coverage

# Yarn
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# Sentry — auth tokens live in SENTRY_AUTH_TOKEN env var, never in repo.
# ios/sentry.properties holds ONLY non-secret coordinates (url/org/project),
# no auth.token, so it is committed on purpose for CI symbol upload.
android/sentry.properties
.sentryclirc

# QA / Figma screenshot + capture artifacts (dev byproducts, not source)
plans/**/*.png
plans/**/*.jpg
plans/**/*.jpeg
plans/**/*.gif
plans/**/*.webp
plans/**/*.mp4
plans/**/*.mov

# web review build output
dist-web/
